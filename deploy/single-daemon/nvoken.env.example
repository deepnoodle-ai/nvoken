# nvoken single_daemon profile
#
# Copy this file to a mode-0600 secret file and populate blank values outside
# version control. The checked example intentionally contains no secret value.

# Fixed profile topology. Do not add Redis or Cloud Tasks to this profile.
NVOKEN_PROCESS_ROLE=combined
INVOCATION_EXECUTION_MODE=embedded
PORT=8080
NVOKEN_PUBLIC_BASE_URL=https://nvoken.example.com
NVOKEN_TRUST_FORWARDED_CLIENT_IP=false

# Operator-provided PostgreSQL 17.x. Require TLS outside a trusted local socket.
DATABASE_URL=
DATABASE_MAX_CONNS=20
MIGRATION_TIMEOUT=5m
DIAGNOSTIC_TIMEOUT=15s

# Installation identity and credential delivery. All three are secret inputs.
# RUNTIME_API_KEY is the optional static Runtime credential used by the smoke
# tooling; leave it blank when only issued machine credentials are accepted.
RUNTIME_API_KEY=
RUNTIME_TENANT_KEY=
BOOTSTRAP_OWNER_SECRET=
CREDENTIAL_DELIVERY_KEY=

# Self-hosted provider policy. At least one installation key is required with
# the default source below. Callers may still select caller_ephemeral.
MODEL_CREDENTIAL_DEPLOYMENT_MODE=self_hosted
INVOCATION_DEFAULT_CREDENTIAL_SOURCE=installation_byok
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional encrypted Account/tenant BYOK. Configure both values together.
PROVIDER_CREDENTIAL_ACTIVE_KEY_ID=
PROVIDER_CREDENTIAL_ENCRYPTION_KEYS=
PROVIDER_CREDENTIAL_CLEANUP_GRACE=5m

# Process and embedded engine safety bounds.
SHUTDOWN_TIMEOUT=60s
ENGINE_CONCURRENCY=8
ENGINE_POLL_INTERVAL=1s
ENGINE_LEASE_DURATION=30s
ENGINE_HEARTBEAT_INTERVAL=10s
ENGINE_REAPER_INTERVAL=10s
ENGINE_REAPER_BATCH_LIMIT=100
ENGINE_DRAIN_GRACE=45s
ENGINE_EXECUTION_SEGMENT_CEILING=15m
ENGINE_SETTLEMENT_RESERVE=5s

# Installation Invocation defaults and maxima.
INVOCATION_DEFAULT_TOTAL_TIMEOUT=30m
INVOCATION_DEFAULT_ACTIVE_TIMEOUT=30m
INVOCATION_DEFAULT_WAITING_TIMEOUT=30m
INVOCATION_DEFAULT_MAX_ITERATIONS=1
INVOCATION_MAX_TOTAL_TIMEOUT=24h
INVOCATION_MAX_ACTIVE_TIMEOUT=24h
INVOCATION_MAX_WAITING_TIMEOUT=24h
INVOCATION_MAX_OUTPUT_TOKENS=1000000
INVOCATION_MAX_ESTIMATED_COST_MICROUSD=1000000000
INVOCATION_MAX_ITERATIONS=100

# In-process live events and Postgres correctness polling.
LIVE_EVENT_BUFFER=64
STREAM_POLL_INTERVAL=1s
STREAM_KEEPALIVE_INTERVAL=15s
STREAM_MAX_LIFETIME=55m
STREAM_WRITE_TIMEOUT=10s

# Bounded transport-diagnostic retention. Embedded execution does not publish
# Cloud Tasks dispatches, but the shared configuration remains validated.
DISPATCH_QUEUE=execution
DISPATCH_PUBLICATION_LEASE=30s
DISPATCH_PUBLISH_RETRY_BASE=1s
DISPATCH_PUBLISH_RETRY_MAX=1m
DISPATCH_STALE_AFTER=5m
DISPATCH_RETENTION=168h
DISPATCH_BATCH_LIMIT=100
DISPATCH_PUBLISH_INTERVAL=1s
DISPATCH_RECONCILE_INTERVAL=1m
DISPATCH_RETENTION_INTERVAL=1h

# Optional callback tools. CALLBACK_SIGNING_KEY is a secret input; when it is
# blank, every other callback value is inert and callback specs are rejected.
CALLBACK_SIGNING_KEY=
CALLBACK_SIGNING_KEY_ID=nvoken/installation/callback
CALLBACK_SIGNING_KEY_VERSION=1
CALLBACK_REQUEST_TIMEOUT=10s
CALLBACK_DNS_TIMEOUT=5s
CALLBACK_CONNECT_TIMEOUT=5s
CALLBACK_TLS_TIMEOUT=5s
CALLBACK_LEASE_DURATION=30s
CALLBACK_RETRY_BASE=1s
CALLBACK_RETRY_MAX=1m
CALLBACK_MAX_ATTEMPTS=5
CALLBACK_RETENTION=168h
CALLBACK_BATCH_LIMIT=100
CALLBACK_CONCURRENCY=4
CALLBACK_POLL_INTERVAL=1s
CALLBACK_RECOVERY_INTERVAL=10s
CALLBACK_RETENTION_INTERVAL=1h
CALLBACK_DRAIN_GRACE=45s
