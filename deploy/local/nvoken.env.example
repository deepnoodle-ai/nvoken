# Disposable localhost development only. deploy/local/configure.py copies this
# file to the ignored repository-root .env and fills the secret values.

NVOKEN_PROCESS_ROLE=combined
INVOCATION_EXECUTION_MODE=embedded
PORT=8080
NVOKEN_PUBLIC_BASE_URL=http://localhost:8080
NVOKEN_TRUST_FORWARDED_CLIENT_IP=false

DATABASE_URL=postgres://nvoken:nvoken-local@127.0.0.1:55432/nvoken?sslmode=disable
DATABASE_MAX_CONNS=10

# Generated independently by configure.py. Never commit the populated values.
RUNTIME_API_KEY=
BOOTSTRAP_OWNER_SECRET=
CREDENTIAL_DELIVERY_KEY=

# configure.py copies exactly the selected key from its process environment.
MODEL_CREDENTIAL_DEPLOYMENT_MODE=self_hosted
INVOCATION_DEFAULT_CREDENTIAL_SOURCE=installation_byok
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Small laptop defaults. These are not production sizing recommendations.
ENGINE_CONCURRENCY=2
SHUTDOWN_TIMEOUT=20s
ENGINE_DRAIN_GRACE=10s

